android/build/

# Auto-generated by the Flutter tool, regenerated on every pub get / build.
# This app is Android-first and never builds macOS, so the macOS registrant
# was pure churn — flipping LF<->CRLF on a Windows checkout and showing up
# as a phantom modification on every status. Untracked (git rm --cached)
# and ignored so it stays out of the way; it regenerates automatically if
# a macOS build is ever needed.
macos/Flutter/GeneratedPluginRegistrant.swift
